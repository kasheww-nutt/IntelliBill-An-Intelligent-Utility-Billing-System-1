<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ToggleButton?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>

<BorderPane fx:id="rootPane" xmlns="http://javafx.com/javafx/26" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.intellibill.controller.DashboardController" styleClass="app-root">
    <top>
        <VBox spacing="14" styleClass="hero-pane">
            <padding>
                <Insets top="16" right="22" bottom="18" left="22"/>
            </padding>

            <HBox alignment="CENTER_LEFT" spacing="10">
                <Label text="IntelliBill" styleClass="hero-title"/>
                <Region HBox.hgrow="ALWAYS"/>
                <Label fx:id="dbStatusBadge" text="DB: Connected" styleClass="top-badge badge-ok"/>
                <Label fx:id="currentUserBadge" text="User: Admin Operator" styleClass="top-badge"/>
                <Label fx:id="lastSyncLabel" text="Last Sync: --" styleClass="top-badge"/>
                <ToggleButton fx:id="themeToggle" text="Light" onAction="#onToggleTheme" styleClass="theme-toggle"/>
            </HBox>

            <Label text="Smart Utility Billing and Consumption Analysis" styleClass="hero-subtitle"/>

            <HBox spacing="12">
                <VBox styleClass="stat-card">
                    <Label text="TOTAL CONSUMERS" styleClass="stat-heading"/>
                    <Label fx:id="consumerCountLabel" text="Consumers: 0" styleClass="stat-value"/>
                </VBox>
                <VBox styleClass="stat-card">
                    <Label text="TOTAL BILLS" styleClass="stat-heading"/>
                    <Label fx:id="billCountLabel" text="Bills: 0" styleClass="stat-value"/>
                </VBox>
                <VBox styleClass="stat-card">
                    <Label text="TOTAL PAYMENTS" styleClass="stat-heading"/>
                    <Label fx:id="paymentCountLabel" text="Payments: 0" styleClass="stat-value"/>
                </VBox>
            </HBox>
            <Label fx:id="persistenceModeLabel" text="Persistence: Checking..." styleClass="hero-subtitle"/>
        </VBox>
    </top>
    <left>
        <VBox spacing="10" styleClass="nav-pane">
            <padding>
                <Insets top="18" right="14" bottom="18" left="14"/>
            </padding>
            <Label text="Navigation" styleClass="nav-title"/>
            <Button text="+ Add Consumer" maxWidth="Infinity" onAction="#onAddConsumer" styleClass="nav-button"/>
            <Button text="* Generate Bill" maxWidth="Infinity" onAction="#onGenerateBill" styleClass="nav-button"/>
            <Button text="[] View Reports" maxWidth="Infinity" onAction="#onViewReports" styleClass="nav-button"/>
            <Region VBox.vgrow="ALWAYS"/>
            <Button text="Refresh Stats" maxWidth="Infinity" onAction="#onRefreshStats" styleClass="secondary-button"/>
        </VBox>
    </left>
</BorderPane>
